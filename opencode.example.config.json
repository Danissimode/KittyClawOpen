{
  "$schema": "https://raw.githubusercontent.com/opencode-ai/opencode/main/packages/server/src/config/schema.json",
  
  "server": {
    "port": 1234,
    "host": "localhost",
    "apiKey": "your-opencode-server-api-key",
    "logLevel": "info",
    "cors": {
      "origins": ["http://localhost:5230", "http://localhost:*"],
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "headers": ["Content-Type", "Authorization"]
    }
  },
  
