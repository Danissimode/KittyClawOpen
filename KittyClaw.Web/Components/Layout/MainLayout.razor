@inherits LayoutComponentBase
@using KittyClaw.Web.Components.TeamChat
@using KittyClaw.Web.Services
@inject TeamChatState ChatState
@inject RunnerStatusState RunnerStatus

<EscapeKeyHost />

@* Persistent Runner Status Bar *@
<RunnerStatusBar />

@* Security notice — local-only tool warning *@
<SecurityBanner />

@Body

<UpdateBanner />

@* Toast notifications *@
<ToastContainer />

@if (!string.IsNullOrEmpty(ChatState.CurrentProjectSlug))
{
    <TeamChatDock ProjectSlug="@ChatState.CurrentProjectSlug" />
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
